{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Knowledge Cat Deck Plan",
  "type": "object",
  "required": ["deck", "slides"],
  "properties": {
    "deck": {
      "type": "object",
      "required": [
        "title",
        "audience",
        "outcome",
        "output_lane",
        "format",
        "slide_count"
      ],
      "properties": {
        "title": { "type": "string" },
        "audience": { "type": "string" },
        "outcome": { "type": "string" },
        "main_promise": { "type": "string" },
        "narrative_spine": { "type": "string" },
        "output_lane": {
          "type": "string",
          "enum": ["native-pptx", "html-deck", "image-first-pptx", "review-only"]
        },
        "format": { "type": "string" },
        "slide_count": { "type": "integer", "minimum": 1 },
        "design_posture": { "type": "string" },
        "style_prompt_source": { "type": "string" },
        "style_prompt_profile": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "selected_prompt": { "type": "string" },
            "visual_dna": { "type": "string" },
            "palette": { "type": "string" },
            "typography": { "type": "string" },
            "texture_material": { "type": "string" },
            "composition": { "type": "string" },
            "text_in_image_policy": { "type": "string" },
            "must_preserve": {
              "type": "array",
              "items": { "type": "string" }
            },
            "must_avoid": {
              "type": "array",
              "items": { "type": "string" }
            },
            "safety_normalization": { "type": "string" }
          }
        },
        "image_generation_strategy": {
          "type": "string",
          "enum": ["none", "full-image-first", "hybrid-image-first", "image-first-html-prototype", "social-carousel"]
        },
        "prompt_log_path": { "type": "string" },
        "assumptions": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "number",
          "action_title",
          "role",
          "key_message",
          "visual"
        ],
        "properties": {
          "number": { "type": "integer", "minimum": 1 },
          "layout": { "type": "string" },
          "action_title": { "type": "string" },
          "role": { "type": "string" },
          "key_message": { "type": "string" },
          "evidence": {
            "type": "array",
            "items": { "type": "string" }
          },
          "visual": { "type": "string" },
          "visual_intent": { "type": "string" },
          "style_variation": { "type": "string" },
          "text_inside_image": { "type": "string" },
          "aspect_ratio": { "type": "string" },
          "prompt_seed": { "type": "string" },
          "prompt_risk": { "type": "string" },
          "speaker_note": { "type": "string" },
          "source_refs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "asset_needs": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
